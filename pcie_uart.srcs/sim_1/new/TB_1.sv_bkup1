always@* if(W_CNT == i) FULL_awlock  [i] <= WR_IMG_awlock  ; else FULL_awlock  [i] <= 'd0;
always@* if(W_CNT == i) FULL_awcache [i] <= WR_IMG_awcache ; else FULL_awcache [i] <= 'd0;

always@* if(W_CNT == i) FULL_wdata   [i] <= WR_IMG_wdata   ; else FULL_wdata   [i] <= 'd0;
always@* if(W_CNT == i) FULL_wstrb   [i] <= WR_IMG_wstrb   ; else FULL_wstrb   [i] <= 'd0;
always@* if(W_CNT == i) FULL_wlast   [i] <= WR_IMG_wlast   ; else FULL_wlast   [i] <= 'd0;
always@* if(W_CNT == i) FULL_wvalid  [i] <= WR_IMG_wvalid  ; else FULL_wvalid  [i] <= 'd0;

always@* if(W_CNT == i) FULL_bready  [i] <= WR_IMG_bready  ; else FULL_bready  [i] <= 'd0;

end endgenerate 
