always@* if(REQ_CHL == (i+1)) FULL_rready  [i] <= RD_IMG_rready  ;else FULL_rready  [i] <= 'd0;

always@* if(W_CNT == i) FULL_awid    [i] <= WR_IMG_awid    ; else FULL_awid    [i] <= 'd0;
always@* if(W_CNT == i) FULL_awaddr  [i] <= WR_IMG_awaddr  ; else FULL_awaddr  [i] <= 'd0;
