	.s12_axi_wdata                         		(FULL_wdata                         		[11]),
	.s12_axi_wstrb                         		(FULL_wstrb                         		[11]),
	.s12_axi_wlast                         		(FULL_wlast                         		[11]),
	.s12_axi_wvalid                        		(FULL_wvalid                        		[11]),
	.s12_axi_wready                        		(FULL_wready                        		[11]),

	.s12_axi_bid                           		(FULL_bid                           		[11]),
	.s12_axi_bresp                         		(FULL_bresp                         		[11]),
	.s12_axi_bvalid                        		(FULL_bvalid                        		[11]),
	.s12_axi_bready                        		(FULL_bready                        		[11]),

	.s12_axi_arid                          		(FULL_arid                          		[11]),
	.s12_axi_araddr                        		(FULL_araddr                        		[11]),
	.s12_axi_arlen                         		(FULL_arlen                         		[11]),
	.s12_axi_arsize                        		(FULL_arsize                        		[11]),
	.s12_axi_arburst                       		(FULL_arburst                       		[11]),
	.s12_axi_arprot                        		(FULL_arprot                        		[11]),
	.s12_axi_arvalid                       		(FULL_arvalid                       		[11]),
	.s12_axi_arlock                        		(FULL_arlock                        		[11]),
	.s12_axi_arcache                       		(FULL_arcache                       		[11]),
	.s12_axi_arready                       		(FULL_arready                       		[11]),

	.s12_axi_rid                           		(FULL_rid                           		[11]),
	.s12_axi_rdata                         		(FULL_rdata                         		[11]),
	.s12_axi_rresp                         		(FULL_rresp                         		[11]),
	.s12_axi_rlast                         		(FULL_rlast                         		[11]),
	.s12_axi_rvalid                        		(FULL_rvalid                        		[11]),
	.s12_axi_rready                        		(FULL_rready                        		[11]),

	.s_axi_lite_awaddr                   		(s_axi_lite_awaddr                   			),
	.s_axi_lite_awprot                   		(s_axi_lite_awprot                   			),
	.s_axi_lite_awvalid                  		(s_axi_lite_awvalid                  			),
	.s_axi_lite_awready                  		(s_axi_lite_awready                  			),

	.s_axi_lite_wdata                    		(s_axi_lite_wdata                    			),
	.s_axi_lite_wstrb                    		(s_axi_lite_wstrb                    			),
	.s_axi_lite_wvalid                   		(s_axi_lite_wvalid                   			),
	.s_axi_lite_wready                   		(s_axi_lite_wready                   			),

	.s_axi_lite_bvalid                   		(s_axi_lite_bvalid                   			),
	.s_axi_lite_bresp                    		(s_axi_lite_bresp                    			),
	.s_axi_lite_bready                   		(s_axi_lite_bready                   			),

	.s_axi_lite_araddr                   		(s_axi_lite_araddr                   			),
	.s_axi_lite_arprot                   		(s_axi_lite_arprot                   			),
	.s_axi_lite_arvalid                  		(s_axi_lite_arvalid                  			),
	.s_axi_lite_arready                  		(s_axi_lite_arready                  			),

	.s_axi_lite_rdata                    		(s_axi_lite_rdata                    			),
	.s_axi_lite_rresp                    		(s_axi_lite_rresp                    			),
	.s_axi_lite_rvalid                   		(s_axi_lite_rvalid                   			),
	.s_axi_lite_rready                   		(s_axi_lite_rready                   			),

	.UART_RX                                 	(UART_TX                                 		),
	.UART_TX                                 	(UART_TX                                 		)
);


initial begin
    clk = 1'd1;
    rst = 1'd1;
    
    #200ns
    `q
    rst = 1'd0;
    
    while(1)
        if(STOP)
            break;
        else
            @(posedge clk);
    $stop;

end

initial begin 
    STOP = 1'd0;
    
    #`SIM_STOP_TIME;
    `q
    STOP = 1;

end

always #4ns clk = ~clk;


//-------------------------------------------------------

initial begin
    W_CNT = 'd0;
    SW = 0;
    CNT = 0;
	CNT_THRD = 0;
	DATA_CNT = 0;
    BAR_BD = 1'd1;
    WR_IMG_awid   = `NO_USE; 
    WR_IMG_awaddr = 'd0; 
    WR_IMG_awlen  =  `NO_USE;
    WR_IMG_awsize =  `NO_USE;
    WR_IMG_awburst=  `NO_USE;
    WR_IMG_awprot =  `NO_USE;
    WR_IMG_awvalid=  'd0;
    WR_IMG_awlock =  `NO_USE;
    WR_IMG_awcache=  `NO_USE;
    
    WR_IMG_wdata   = 'd0;
    WR_IMG_wstrb   = 'd0;
    WR_IMG_wlast   = 'd0;
    WR_IMG_wvalid  = 'd0;
    
    WR_IMG_bready  = `NO_USE;
    
    WAIT_RESET;
    
    #`RD_IMG_WAIT_WRITE;
    
    while(1) begin
        case(SW)
            0:	begin
                    `q
					CNT_THRD = ({$random} % 1024) + 1;
                    if(WR_IMG_awready & BAR_BD) begin
                        WR_IMG_awaddr  = W_BASE_ADDR[W_CNT*64+:64];
                        WR_IMG_awvalid = 1'd1;
                        SW = 1;
                        if(WR_IMG_wready) begin
                            WR_IMG_WR_DATA;
                        end
                        
                    end
                end
        
            1:	begin
                    `q
                    WR_IMG_awvalid = 1'd0;
					
					if(CNT == CNT_THRD) begin
						WR_IMG_wdata  = 'd0;
						WR_IMG_wstrb  = 'd0;
						WR_IMG_wlast  = 'd0;
						WR_IMG_wvalid = 'd0;
						WR_IMG_bready = 1'd1;
						CNT = 0;
						SW = 2;
						@(posedge clk);
					end
					else if(WR_IMG_wready) begin
						WR_IMG_WR_DATA;
                    end
                end
        
            2:	begin
                    `q
                        WR_IMG_bready = 1'd1;
                        SW = 3;
                end
                
            3:	begin
                    #`WRITE_INTERVAL;
                    `q
					if(W_CNT == 11)
						W_CNT = 0;
					else
						W_CNT = W_CNT + 1;
                    SW = 0;
                end			

            default:;
        endcase
    end
end

initial begin
    READ_DONE = 1'd0;
    AR_SW = 0;
    CNT = 0;
    RD_IMG_arid    = `NO_USE;
    RD_IMG_araddr  = 'd0;
    RD_IMG_arlen   = `NO_USE;
    RD_IMG_arsize  = `NO_USE;
    RD_IMG_arburst = `NO_USE;
    RD_IMG_arprot  = `NO_USE;
    RD_IMG_arvalid = 'd0;
    RD_IMG_arlock  = `NO_USE;
    RD_IMG_arcache = `NO_USE;
    
    RD_IMG_rready  = 'd0;
    
    WAIT_RESET;
    
    while(1) begin
        `q
        if((!AR_SW) & RD_IMG_arready & READ_START) begin
            RD_IMG_araddr = R_BASE_ADDR[(REQ_CHL - 1)*64+:64];
            RD_IMG_arvalid = (!READ_STOP);
            AR_SW = 1;
            READ_START = 0;
            RD_IMG_rready = 1'd1;
        end
        else if(AR_SW) begin
            if(RD_IMG_rlast) begin
                AR_SW = 0;
                READ_DONE = 1'd1;
            end
            else begin
                RD_IMG_araddr  = 'd0;	
                RD_IMG_arvalid = 'd0;
                READ_DONE = 1'd0;
            end
        end
        else begin
            RD_IMG_araddr  = 'd0;
            RD_IMG_arvalid = 'd0;
            RD_IMG_rready  = 'd0;
        end
    end	
end

initial begin 
    LOG_SW = 0;
    REQ_CHL = 0;
    READ_START = 0;
    
    s_axi_lite_awaddr  = 'd0;   
    s_axi_lite_awprot  = 'd0;   
    s_axi_lite_awvalid = 'd0;   

    s_axi_lite_wdata   = 'd0;   
    s_axi_lite_wstrb   = 'd0;   
    s_axi_lite_wvalid  = 'd0;   

    s_axi_lite_bready  = 'd0;

    s_axi_lite_araddr     = 'd0;
    s_axi_lite_arprot     = 'd0;
    s_axi_lite_arvalid    = 'd0;

    s_axi_lite_rready     = 'd0;

    WAIT_RESET;
	
	`q
	LITE_WRITE(32'h0000_0020, 0);
	`q
	LITE_WRITE(32'h0000_0024, `AXI_RD_LEN);
	`q
	LITE_WRITE(32'h0000_0048, 1000000);
	`q
	LITE_WRITE(32'h0000_0040, 1);
	`q
	LITE_WRITE(32'h0000_0044, 1);
	
	#2us;
	`q
	LITE_WRITE(32'h0000_0088, 1000000);
	`q
	LITE_WRITE(32'h0000_0080, 1);
	`q
	LITE_WRITE(32'h0000_0084, 1);
	
	while(1) begin
        `q `q `q `q
		@(negedge clk);
		#1ns;
		if(s_axi_lite_arready) begin
			s_axi_lite_araddr = 'h128;
			s_axi_lite_arvalid = 1'd1;
			s_axi_lite_rready = 1'd1;
			@(posedge clk);
			`q
			if(s_axi_lite_rvalid & (s_axi_lite_rdata >= `AXI_RD_LEN)) begin
				s_axi_lite_arvalid = 1'd0;
				break;
			end
			
			#1ns;
			s_axi_lite_arvalid = 1'd0;
			
		end
	end
	
	//RD1;
	RD2;

end

initial begin
    READ_STOP = `READ_STOP_EN;
    
    #`READ_STOP_TIME;
    `q
    READ_STOP = 1'd0;
    
end
initial begin
	INIT = 1'd0;
end

task WAIT_RESET; begin
    while(1) begin
        if(rst == 0)
            break;
        else
            @(posedge clk);
    end
    
    repeat(10)
        @(posedge clk);
end endtask	


task LITE_WRITE(input [31:0] awaddr, input [31:0] wdata); begin
        
    `q
    s_axi_lite_awaddr  = awaddr;
    s_axi_lite_awvalid = 1'd1;
    
    `q
    s_axi_lite_awaddr  = 'd0;
    s_axi_lite_awvalid = 'd0;
    
    s_axi_lite_wdata   = wdata;
    s_axi_lite_wstrb   = 4'hf;
    s_axi_lite_wvalid  = 'd1;
    s_axi_lite_bready  = 'd1;
    
    `q
    s_axi_lite_wdata   = 'd0;
    s_axi_lite_wstrb   = 'd0;
    s_axi_lite_wvalid  = 'd0;
    s_axi_lite_bready  = 'd1;
    
    `q
    s_axi_lite_bready  = 'd0;
    
    `q

end endtask 

task RD1; begin

	while(1) begin
		`q
		// if(DUT.GF_CHL[0].UART_R.rx_cnt == 3) begin
		if(DUT.GF_CHL[0].UART_R.LR_RFF_USEDW == 9) begin
			REQ_CHL = 1;
			READ_START = 1;
			break;
		end
	end
	
	#500us;
	`q
	LITE_WRITE(32'h0000_0024, 16);
	`q
	READ_START = 1;
	
	#500us;
	`q
	LITE_WRITE(32'h0000_0024, 21);
	`q
	READ_START = 1;

end endtask

task RD2; begin

	while(1) begin
		`q
		// if(DUT.GF_CHL[0].UART_R.rx_cnt == 3) begin
		if(DUT.GF_CHL[0].UART_R.LR_RFF_USEDW == 9) begin
			REQ_CHL = 1;
			READ_START = 1;
			break;
		end
	end
	
	#100us;
	`q
	LITE_WRITE(32'h0000_0024, 1);
	`q
	READ_START = 1;
	
	#100us;
	`q
	LITE_WRITE(32'h0000_0024, 2);
	`q
	READ_START = 1;
	
	#100us;
	`q
	LITE_WRITE(32'h0000_0024, 3);
	`q
	READ_START = 1;
	
	#100us;
	`q
	LITE_WRITE(32'h0000_0024, 2);
	`q
	READ_START = 1;
	
	#100us;
	`q
	LITE_WRITE(32'h0000_0024, 2);
	`q
	READ_START = 1;

end endtask

task WR_IMG_WR_DATA; begin
	WR_IMG_wstrb  = STRB({$random} % 9);
	WR_IMG_wdata  = DATA(WR_IMG_wstrb, DATA_CNT);
	WR_IMG_wlast  = CNT == (CNT_THRD - 1);
	WR_IMG_wvalid = 1'd1;

	`q
	CNT = CNT + 1;
	DATA_CNT = DATA_CNT + WR_IMG_wstrb[7] + WR_IMG_wstrb[6] + WR_IMG_wstrb[5] + WR_IMG_wstrb[4] + WR_IMG_wstrb[3] + WR_IMG_wstrb[2] + WR_IMG_wstrb[1] + WR_IMG_wstrb[0];

end endtask

task DP_INVL; begin
	$display("");
	$display("");
end endtask

function [7:0] STRB;
	input [31:0] D_NUM;
	//
	STRB = (D_NUM == 1) ? (8'h01 << ({$random} % 8))
		 : (D_NUM == 2) ? (8'h03 << ({$random} % 7))           
		 : (D_NUM == 3) ? (8'h07 << ({$random} % 6))           
		 : (D_NUM == 4) ? (8'h0f << ({$random} % 5))           
		 : (D_NUM == 5) ? (8'h1f << ({$random} % 4))           
		 : (D_NUM == 6) ? (8'h3f << ({$random} % 3))           
		 : (D_NUM == 7) ? (8'h7f << ({$random} % 2))           
		 : (D_NUM == 7) ? 8'hff : 0;           
endfunction

function [63:0] DATA;
	input [7:0] STRB;
	input [7:0] DATA_BASE;
	
	DATA = (STRB == 8'b0000_0001) ? ({56'd0, DATA_BASE} << 0)
		 : (STRB == 8'b0000_0010) ? ({56'd0, DATA_BASE} << 8)
		 : (STRB == 8'b0000_0100) ? ({56'd0, DATA_BASE} << 16)
		 : (STRB == 8'b0000_1000) ? ({56'd0, DATA_BASE} << 24)
		 : (STRB == 8'b0001_0000) ? ({56'd0, DATA_BASE} << 32)
		 : (STRB == 8'b0010_0000) ? ({56'd0, DATA_BASE} << 40)
		 : (STRB == 8'b0100_0000) ? ({56'd0, DATA_BASE} << 48)
		 : (STRB == 8'b1000_0000) ? ({56'd0, DATA_BASE} << 56)
		 
		 : (STRB == 8'b0000_0011) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 0)
		 : (STRB == 8'b0000_0110) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 8)
		 : (STRB == 8'b0000_1100) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 16)
		 : (STRB == 8'b0001_1000) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 24)
		 : (STRB == 8'b0011_0000) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 32)
		 : (STRB == 8'b0110_0000) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 40)
		 : (STRB == 8'b1100_0000) ? ({48'd0, (DATA_BASE+1), DATA_BASE} << 48)
		 
		 : (STRB == 8'b0000_0111) ? ({40'd0, (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 0)
		 : (STRB == 8'b0000_1110) ? ({40'd0, (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 8)
		 : (STRB == 8'b0001_1100) ? ({40'd0, (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 16)
		 : (STRB == 8'b0011_1000) ? ({40'd0, (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 24)
		 : (STRB == 8'b0111_0000) ? ({40'd0, (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 32)
		 : (STRB == 8'b1110_0000) ? ({40'd0, (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 40)
		 
		 : (STRB == 8'b0000_1111) ? ({32'd0, (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 0)
		 : (STRB == 8'b0001_1110) ? ({32'd0, (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 8)
		 : (STRB == 8'b0011_1100) ? ({32'd0, (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 16)
		 : (STRB == 8'b0111_1000) ? ({32'd0, (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 24)
		 : (STRB == 8'b1111_0000) ? ({32'd0, (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 32)
		 
		 : (STRB == 8'b0001_1111) ? ({24'd0, (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 0)
		 : (STRB == 8'b0011_1110) ? ({24'd0, (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 8)
		 : (STRB == 8'b0111_1100) ? ({24'd0, (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 16)
		 : (STRB == 8'b1111_1000) ? ({24'd0, (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 24)
		 
		 : (STRB == 8'b0011_1111) ? ({16'd0, (DATA_BASE+5), (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 0)
		 : (STRB == 8'b0111_1110) ? ({16'd0, (DATA_BASE+5), (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 8)
		 : (STRB == 8'b1111_1100) ? ({16'd0, (DATA_BASE+5), (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 16)
		 
		 : (STRB == 8'b0111_1111) ? ({8'd0, (DATA_BASE+6), (DATA_BASE+5), (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 0)
		 : (STRB == 8'b1111_1110) ? ({8'd0, (DATA_BASE+6), (DATA_BASE+5), (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 8)
		 
		 : (STRB == 8'b1111_1111) ? ({(DATA_BASE+7), (DATA_BASE+6), (DATA_BASE+5), (DATA_BASE+4), (DATA_BASE+3), (DATA_BASE+2), (DATA_BASE+1), DATA_BASE} << 0) : 0;

		
endfunction 

endmodule
