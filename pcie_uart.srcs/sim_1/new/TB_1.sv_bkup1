generate for (i=0; i < 12; i = i + 1)begin : GF1
always@* if(REQ_CHL == (i+1)) FULL_arid    [i] <= RD_IMG_arid    ;else FULL_arid    [i] <= 'd0;
always@* if(REQ_CHL == (i+1)) FULL_araddr  [i] <= RD_IMG_araddr  ;else FULL_araddr  [i] <= 'd0;
